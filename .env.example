# GUT-TRACKER – Variables de entorno (copiar a .env y ajustar)
# Todas las apps del monorepo leen desde este archivo en la raíz.

# API (Flask) – ejecutar desde api/ con Pipenv (pipenv run dev)
FLASK_APP=app:app
FLASK_ENV=development
SQLALCHEMY_DATABASE_URI=sqlite:///instance/registros.db

# App (Vite) – prefijo VITE_ para exponer en el cliente
VITE_API_URL=http://127.0.0.1:5000
